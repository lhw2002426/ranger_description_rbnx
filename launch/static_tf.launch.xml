<!--
  Static TF tree for Ranger Mini until soma (URDF + robot_state_publisher)
  ships in robonix v0.2.

  This file is the minimum viable replacement for `ranger_description`'s
  display.launch.py: it publishes the same `base_link → sensor_*` static
  edges that RSP would produce from URDF, but skips the URDF / mesh /
  joint_state machinery (mapping and nav don't need wheel-joint TF, and
  joint_state_publisher would clash with the chassis driver's own
  /joint_states once that ships).

  ─────────────────────────────────────────────────────────────────────
  Frame contract (must match the rest of the deploy)
  ─────────────────────────────────────────────────────────────────────
    base_link
        chassis frame; ground projection of the geometric centre.
        X forward, Y left, Z up. Owned by the chassis driver
        (ranger_chassis_rbnx with publish_odom_tf: true emits
        odom → base_link).

    livox_frame
        MID-360 mount frame. The Livox driver publishes PointCloud2
        with frame_id="livox_frame" (hard-coded in the driver), so
        this IS the frame name we have to match — do not rename.

    camera_435i_link
        RealSense D435i body mount. Note the `camera_435i` prefix:
        realsense2_camera builds frame names as
            "<camera_name>_<base_frame_id>"
        and the deploy sets camera_name=camera_435i (see
        robonix_manifest.yaml → realsense_camera.config). The
        common mistake here is to publish to `camera_link` —
        nothing in the rest of the deploy uses that frame, so
        rtabmap's RGBD path will silently fail TF lookups.

    camera_435i_color_optical_frame, *_depth_optical_frame, etc.
        Published by realsense2_camera itself off camera_435i_link.
        Do NOT add static TFs for these here; the driver owns them.

  ─────────────────────────────────────────────────────────────────────
  Mount offset values (xyz / rpy)
  ─────────────────────────────────────────────────────────────────────
  The defaults below are derived from old_cap/ranger_description's
  ranger_mini.xacro mechanical chain:

      base_link → box_link            xyz=(0.03, 0,    0    )
      box_link  → livox_frame         xyz=(0.15, 0,    0.275)
      box_link  → camera_435i_*       xyz=(0.25, 0,    0.15 )
                  + d435 internal mesh offset (~0.03 in X)

  Folded down to single base_link → sensor edges:

      base_link → livox_frame         ≈ (0.18, 0, 0.425)
      base_link → camera_435i_link    ≈ (0.28, 0, 0.30 )

  These are PLACEHOLDERS derived from CAD, NOT measurements from your
  physical robot. Mis-calibrated TF is the single most common reason
  rtabmap "thinks the robot is jumping around" or nav goals land 30 cm
  off. Override the launch args from the deploy manifest's
  `ranger_description.config.launch_args` block with values measured
  against your actual hardware before relying on this for SLAM / nav.

  ─────────────────────────────────────────────────────────────────────
  Run (standalone, for testing without rbnx)
  ─────────────────────────────────────────────────────────────────────
      ros2 launch ranger_description_rbnx/launch/static_tf.launch.xml

  Override mount offsets without editing the file:

      ros2 launch ranger_description_rbnx/launch/static_tf.launch.xml \
          lidar_x:=0.18 lidar_z:=0.42 \
          camera_x:=0.28 camera_z:=0.30

  Under rbnx, the same overrides go into the deploy manifest:

      primitive:
        - name: ranger_description
          config:
            launch_args:
              lidar_x:  "0.18"
              lidar_z:  "0.42"
              camera_x: "0.28"
              camera_z: "0.30"

  ─────────────────────────────────────────────────────────────────────
  Things this file intentionally does NOT publish
  ─────────────────────────────────────────────────────────────────────
  - odom → base_link
        Owned by ranger_chassis_rbnx (publish_odom_tf: true in
        robonix_manifest.yaml). Adding it here would create two
        publishers for the same edge and the TF tree would oscillate.

  - map → odom
        Owned by rtabmap (publish_tf: True in mapping_rbnx's
        rtabmap_2d.launch.py).

  - base_link → base_ground
        ranger_description (the original ROS package this stand-in
        replaces) ships this as a viz-only virtual frame. Mapping /
        nav don't read it, so it's omitted to keep the TF tree
        minimal. Add a static_transform_publisher here if you need
        it for an RViz config.

  - /joint_states, /robot_description
        The original ranger_description launched joint_state_publisher
        and robot_state_publisher to provide these. Mapping / nav
        don't subscribe to either, and starting JSP here would race
        against the chassis driver's own /joint_states once that
        lands. Skip both until soma takes over.

  - Wheel-joint dynamic TF (fl_wheel, fr_wheel, …)
        Only needed for visualising the chassis spinning its wheels
        in RViz. SLAM and nav don't need it.
-->
<launch>
  <!-- ── base_link → livox_frame ──────────────────────────────────────
       MID-360 lidar mount. The Livox driver publishes PointCloud2
       with frame_id=livox_frame, so this static edge lets rtabmap
       transform the cloud into base_link.

       Defaults derived from ranger_mini.xacro CAD; measure the
       actual mount on your robot and override with launch args. -->
  <arg name="lidar_x"     default="0.18"/>
  <arg name="lidar_y"     default="0.00"/>
  <arg name="lidar_z"     default="0.425"/>
  <arg name="lidar_roll"  default="0.0"/>
  <arg name="lidar_pitch" default="0.0"/>
  <arg name="lidar_yaw"   default="0.0"/>
  <node pkg="tf2_ros" exec="static_transform_publisher" name="tf_base_to_lidar"
        args="--x $(var lidar_x) --y $(var lidar_y) --z $(var lidar_z)
              --roll $(var lidar_roll) --pitch $(var lidar_pitch) --yaw $(var lidar_yaw)
              --frame-id base_link --child-frame-id livox_frame"/>

  <!-- ── base_link → camera_435i_link ─────────────────────────────────
       RealSense D435i body mount. realsense2_camera owns everything
       below camera_435i_link (color/depth/IR optical frames, IMU
       frames); we only supply the edge from chassis to camera body.

       Frame name MUST match deploy's camera_name=camera_435i — see
       header for why `camera_link` (the obvious-looking name) is
       wrong here. -->
  <arg name="camera_x"     default="0.28"/>
  <arg name="camera_y"     default="0.00"/>
  <arg name="camera_z"     default="0.30"/>
  <arg name="camera_roll"  default="0.0"/>
  <arg name="camera_pitch" default="0.0"/>
  <arg name="camera_yaw"   default="0.0"/>
  <node pkg="tf2_ros" exec="static_transform_publisher" name="tf_base_to_camera"
        args="--x $(var camera_x) --y $(var camera_y) --z $(var camera_z)
              --roll $(var camera_roll) --pitch $(var camera_pitch) --yaw $(var camera_yaw)
              --frame-id base_link --child-frame-id camera_435i_link"/>
</launch>
